# Copie ce fichier en .env.local et remplis les valeurs.
# .env.local est gitignored (voir .gitignore racine).

# API Netlify prod
API_BASE_URL=https://leafy-sprinkles-69584e.netlify.app
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Racine OneDrive locale : doit pointer vers "02_Pôle RH" (PAS vers Salariés directement).
# L'agent créera dedans :
#   - Salariés/<nom-prenom>/ pour les CDI/CDD
#   - Intérimaires/<agence>/<nom-prenom>/ pour les intérimaires
#   - _archived/<date>/... pour les dossiers de workers inactifs (Stratégie C)
ONEDRIVE_ROOT=/Users/davidbonavia/Library/CloudStorage/OneDrive-Bibliothèquespartagées-Iziship/Sébastien Berthuy - Izilog/02_Pôle RH

# Token partagé pour /api/sync/pending et /complete (poll-loop.mjs).
# Génère via : openssl rand -hex 32
# Doit être identique côté Netlify env (Site settings > Environment variables).
SYNC_AGENT_TOKEN=
